# MongoDB (development — localhost only)
MONGODB_URI=mongodb://localhost:27017

# JWT
JWT_SECRET=change-this-to-a-secure-random-secret-min-32-chars
JWT_EXPIRY=8h

# LLM endpoint — points to Mock LLM server in local dev
# Production value: http://192.168.10.20:11434
OLLAMA_URL=http://localhost:11434

# Ingestion
INGESTION_WATCH_DIR=./data/secure-docs/incoming

# Embedding model
# [DEV ADAPTATION] Production: nomic-embed-text-v1 (768-dim)
# Local dev: all-MiniLM-L6-v2 (384-dim) — lighter, faster, fits in 4GB RAM
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# FAISS
FAISS_INDEX_PATH=./data/faiss/ncmm_dev.index
FAISS_LOOKUP_PATH=./data/faiss/ncmm_dev_lookup.json

# Classifier
CLASSIFIER_REJECT_THRESHOLD=0.85
CLASSIFIER_ALLOWLIST_PATH=./scripts/classifier_allowlist.json

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ADMIN_PASSWORD=change-this-password

# Azure (production only — leave blank locally)
AZURE_SWA_TOKEN=
AZURE_COSMOS_URI=

# App
PORT=3000
NODE_ENV=development

# [DEV ADAPTATION] Mock LLM settings — no equivalent in production
MOCK_LLM_PORT=11434
MOCK_LLM_RESPONSE_DELAY_MS=500
