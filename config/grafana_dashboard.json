{
  "annotations": { "list": [] },
  "title": "NCMM Intelligence Platform",
  "uid": "ncmm-dev-dashboard",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Chunks Ingested (Total)",
      "type": "stat",
      "targets": [{ "expr": "ai_chunks_ingested_total", "legendFormat": "Total Chunks" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "ABAC Denials (Total)",
      "type": "stat",
      "targets": [{ "expr": "ai_abac_denials_total", "legendFormat": "Total Denials" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Query Latency (ms)",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(ai_query_latency_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.50, rate(ai_query_latency_ms_bucket[5m]))", "legendFormat": "p50" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }
    },
    {
      "id": 4,
      "title": "LLM Inference Latency (ms)",
      "type": "graph",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(ai_llm_inference_latency_ms_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.50, rate(ai_llm_inference_latency_ms_bucket[5m]))", "legendFormat": "p50" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }
    }
  ]
}
